{
  "name": "orcs-db",
  "version": "0.3.0",
  "description": "TypeScript MySQL library with query builder, ORM codegen, and migrations",
  "author": "incadawr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/destruction-studio/orcs-db.git"
  },
  "bugs": {
    "url": "https://github.com/destruction-studio/orcs-db/issues"
  },
  "homepage": "https://github.com/destruction-studio/orcs-db#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "orcs-db": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mysql",
    "mysql2",
    "orm",
    "query-builder",
    "codegen",
    "migrations",
    "typescript"
